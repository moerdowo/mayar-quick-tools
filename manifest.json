{
  "manifest_version": 3,
  "name": "Mayar Quick Tools",
  "version": "1.0.0",
  "description": "Generate Mayar dynamic QRIS, single payment request links, and invoices in one click.",
  "action": {
    "default_title": "Mayar Quick Tools",
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  },
  "permissions": ["storage", "downloads"],
  "host_permissions": [
    "https://api.mayar.id/*",
    "https://media.mayar.id/*"
  ]
}
